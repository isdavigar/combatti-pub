rules_version = '2';

// =====================================================================
// Reglas de seguridad de Firestore para Combatti PUB · POS Restaurante
// =====================================================================
//
// COMO PUBLICARLAS:
//   1. Firebase Console -> Firestore Database -> pestaña "Reglas".
//   2. Pega el contenido de este archivo y pulsa "Publicar".
//   (o con CLI:  firebase deploy --only firestore:rules)
//
// REQUISITO: la app inicia sesion de forma ANONIMA automaticamente.
//   Activa el proveedor en Firebase Console ->
//   Authentication -> Sign-in method -> Anonymous -> Habilitar.
//
// Modelo de datos que usa la app:
//   restaurants/{restaurantId}
//     restaurants/{restaurantId}/orders/{docId}
//     restaurants/{restaurantId}/tables/{docId}
//     restaurants/{restaurantId}/products/{docId}
//     restaurants/{restaurantId}/movements/{docId}
//     restaurants/{restaurantId}/supplies/{docId}
//     restaurants/{restaurantId}/deliveryZones/{docId}
//     restaurants/{restaurantId}/kitchenTickets/{docId}
//     restaurants/{restaurantId}/deletedOrders/{docId}
//     restaurants/{restaurantId}/users/{docId}
//     restaurants/{restaurantId}/config/business
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Solo usuarios autenticados (sesion anonima de tu app) pueden leer/escribir.
    // Bloquea el acceso publico anonimo SIN token de tu aplicacion.
    match /restaurants/{restaurantId} {
      allow read, write: if request.auth != null;

      match /{collection}/{docId} {
        allow read, write: if request.auth != null;
      }
    }

    // Todo lo demas queda denegado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

// ---------------------------------------------------------------------
// OPCION MAS ESTRICTA (recomendada para produccion / multi-local):
// Si en el futuro cada local tiene su propia cuenta de usuario real
// (email/clave), puedes limitar cada restaurante a usuarios autorizados
// guardando los UID permitidos en el documento del restaurante:
//
//   match /restaurants/{restaurantId} {
//     allow read, write: if request.auth != null
//       && request.auth.uid in resource.data.allowedUids;
//   }
//
// Y al crear el restaurante, guarda allowedUids: [uid1, uid2, ...].
// ---------------------------------------------------------------------
