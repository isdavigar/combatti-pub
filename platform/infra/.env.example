# ============================================================
# Variables de entorno para el despliegue del backend (docker compose).
# Copia este archivo a `.env` en este mismo directorio y completa los valores.
# docker compose lee automaticamente el archivo `.env`.
# ============================================================

# Secreto de firma JWT. DEBE ser fuerte (>= 32 bytes) y el MISMO en todos los
# servicios. Genera uno con:  openssl rand -base64 48
JWT_SECRET=CAMBIA-ESTO-por-un-secreto-fuerte-de-al-menos-32-bytes

# Usuario administrador inicial (se crea solo si la BD esta vacia).
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=CAMBIA-esta-clave-por-una-fuerte

# Origen(es) permitido(s) por CORS = la URL publica del frontend (Cloudflare Pages).
# Si usas el proxy de Pages Functions (mismo origen), puedes dejar el valor por defecto.
CORS_ALLOWED_ORIGINS=https://combatti-pub.pages.dev
